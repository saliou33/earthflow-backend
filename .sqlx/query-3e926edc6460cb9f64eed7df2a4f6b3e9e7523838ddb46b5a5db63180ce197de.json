  "query": "\n        UPDATE workflows\n        SET \n            name = COALESCE($1, name),\n            description = COALESCE($2, description),\n            graph = COALESCE($3, graph),\n            tags = COALESCE($4, tags),\n            is_public = COALESCE($5, is_public),\n            updated_at = now()\n        WHERE id = $6 AND owner_id = $7\n        RETURNING *\n        ",
